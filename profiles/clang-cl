# Windows clang-cl profile.

include(./base)

{% set compiler = os.getenv("EVGET_COMPILER") or detect_api.detect_clang_compiler("clang-cl") %}
{% set version = os.getenv("EVGET_VERSION") or compiler[1].major %}

[settings]
compiler={{ compiler[0] }}
compiler.version={{ version }}
compiler.cppstd=23
compiler.runtime=dynamic
compiler.runtime_version=v143

[conf]
tools.build:compiler_executables={'c': '{{ compiler[2] }}', 'cpp': '{{ compiler[2] }}'}
tools.cmake.cmaketoolchain:generator=Ninja
