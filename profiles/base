# Shared base profile.

{% set operating_system = os.getenv("EVGET_OS") or detect_api.detect_os() %}
{% set architecture = os.getenv("EVGET_ARCH") or detect_api.detect_arch() %}

[settings]
os={{ operating_system }}
arch={{ architecture }}
build_type=Debug

[conf]
# Give each compiler its own build tree so switching toolchains never collides.
tools.cmake.cmake_layout:build_folder_vars=['settings.compiler', 'settings.build_type']
