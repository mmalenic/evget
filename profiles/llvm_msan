# Compilation with clang and the llvm MemorySanitizer.

include(./llvm_libc)

{% set flags = ['-fsanitize=memory', '-fno-omit-frame-pointer', '-fsanitize-memory-track-origins=2'] %}

[conf]
tools.build:cxxflags+={{ flags }}
tools.build:cflags+={{ flags }}
tools.build:sharedlinkflags+={{ flags }}
tools.build:exelinkflags+={{ flags }}
