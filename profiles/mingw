# Compilation using mingw and default flags.

include(./default_flags)

{% set version = os.getenv("COMPILER_VERSION") | default("14") %}

[settings]
os=Windows
arch=x86_64
compiler=gcc
compiler.version={{ version }}
compiler.cppstd=23
compiler.libcxx=libstdc++11
build_type=Release

[conf]
tools.build:compiler_executables={'c': 'x86_64-w64-mingw32-gcc', 'cpp': 'x86_64-w64-mingw32-g++'}
tools.cmake.cmaketoolchain:generator=Ninja
