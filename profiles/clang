# Clang profile.

include(./base)

{% set compiler = os.getenv("EVGET_COMPILER") or detect_api.detect_clang_compiler() %}
{% set version = os.getenv("EVGET_VERSION") or compiler[1].major %}

[settings]
compiler={{ compiler[0] }}
compiler.version={{ version }}
compiler.cppstd=23
compiler.libcxx=libstdc++11

[conf]
tools.build:compiler_executables={'c': 'clang', 'cpp': 'clang++'}
